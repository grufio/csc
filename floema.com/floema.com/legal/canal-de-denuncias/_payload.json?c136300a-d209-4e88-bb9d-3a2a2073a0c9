[{"data":1,"prerenderedAt":58},["ShallowReactive",2],{"sanity-VnWSRyaq5k":3},{"_type":4,"metadata":5,"sections":12},"page.legal",{"description":6,"image":7,"keywords":8,"sitedescription":6,"sitename":9,"slug":10,"title":11},"Descripción de Floema","https://cdn.sanity.io/images/535lnz3g/production/df589f2e1e3f96da26e95b8e66e35dcac943ec82-2400x1260.jpg",null,"Site Floema","canal-de-denuncias"," Canal de Denúncias",[13,17],{"_type":14,"_updatedAt":8,"subtitle":15,"title":16},"header","De acordo com a Lei n.º 93/2021, de 20 de dezembro, o canal de denúncias interno é um canal seguro de comunicação para efeitos de denúncias sobre atos ou ações em desconformidade com nossos princípios e/ou a legislação vigente.","Canal de Denúncias",{"_type":18,"content":19,"leftTitle":8,"type":4},"content",[20],{"_key":21,"_type":22,"leftTitle":23,"textBlock":24},"5bd73008c288","items","Compromisso Floema",[25,36,50],{"_key":26,"_type":27,"children":28,"markDefs":34,"style":35},"766219497349","block",[29],{"_key":30,"_type":31,"marks":32,"text":33},"7e4fb095bb54","span",[],"A Floema, Lda. assume o compromisso de sigilo, seriedade e cautela quanto às possíveis denúncias de desrespeito e o compromisso de investigar o fato informado e não retaliar ou adotar quaisquer medidas coercitivas contra o colaborador ou terceiro que fizer a comunicação de boa-fé.\n\nEm caso de irregularidades e ilegalidades pode efetuar através do preenchimento do formulário que se segue. Pedimos que preencham o formulário de forma detalhada e consciente para os Recursos Humanos darem início ao processo de investigação.\n\nO questionário pode ser respondido de forma anónima. Em caso de não ser enviada anonimamente, garantimos a proteção dos dados pessoais de acordo com o Regulamento Geral sobre a Proteção de Dados.",[],"normal",{"_key":37,"_type":27,"children":38,"markDefs":44,"style":35},"68c7db70e279",[39],{"_key":40,"_type":31,"marks":41,"text":43},"b39674d8afb9",[42],"c15037615612","Regulamento do Canal de Denúncias Interno ",[45],{"_key":42,"_type":46,"to":47},"internaLink",{"_ref":48,"_type":49},"668fe871-80be-4382-ba42-615366ab0f93","reference",{"_key":51,"_type":27,"children":52,"markDefs":57,"style":35},"b4a82edd94ca",[53],{"_key":54,"_type":31,"marks":55,"text":56},"165df543dab8",[],"Submeter denúncia",[],1783611221907]