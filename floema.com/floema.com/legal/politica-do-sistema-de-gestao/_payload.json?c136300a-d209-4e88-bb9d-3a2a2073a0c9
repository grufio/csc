[{"data":1,"prerenderedAt":159},["ShallowReactive",2],{"sanity-Iu74amJeeR":3},{"_type":4,"metadata":5,"sections":12},"page.legal",{"description":6,"image":7,"keywords":8,"sitedescription":6,"sitename":9,"slug":10,"title":11},"Descripción de Floema","https://cdn.sanity.io/images/535lnz3g/production/4d6dad26c651915c30c7122997bdd50b858895df-2400x1260.jpg","Política do sistema de gestão, floema","Site Floema","politica-do-sistema-de-gestao","Política do Sistema de Gestão",[13,17],{"_type":14,"_updatedAt":15,"subtitle":16,"title":11},"header",null,"Revisão nº 00 de 01 de junho de 2026",{"_type":18,"content":19,"leftTitle":15,"type":4},"content",[20,131],{"_key":21,"_type":22,"textBlock":23},"ba27e3fe47a3","items",[24,35,43,53,60,67,74,81,88,95,102,109,116,123],{"_key":25,"_type":26,"children":27,"markDefs":33,"style":34},"e575d871f20b","block",[28],{"_key":29,"_type":30,"marks":31,"text":32},"518dbb745b1f","span",[],"Na Floema acreditamos que cada produto que concebemos deve ir além da sua função primordial. Desenvolvemos soluções com um profundo respeito pela integração na paisagem, valorização do património e identidade cultural, aliando a sustentabilidade e a economia circular à máxima robustez e durabilidade.\n\nÉ com estes propósitos que assumimos o âmbito do nosso negócio: design e desenvolvimento, produção, comercialização e instalação de sinalética, mobiliário urbano e estruturas de visitação.",[],"normal",{"_key":36,"_type":26,"children":37,"markDefs":42,"style":34},"3fa2a072c5f3",[38],{"_key":39,"_type":30,"marks":40,"text":41},"80bb544f989f",[],"Comprometemo-nos a:",[],{"_key":44,"_type":26,"children":45,"level":50,"listItem":51,"markDefs":52,"style":34},"a8f1709a9a81",[46],{"_key":47,"_type":30,"marks":48,"text":49},"19570700a62e",[],"compreender as necessidades e expectativas dos clientes e de outras partes interessadas relevantes, transformando-as em soluções adequadas, fiáveis e diferenciadoras;",1,"bullet",[],{"_key":54,"_type":26,"children":55,"level":50,"listItem":51,"markDefs":59,"style":34},"500d36cbaf6c",[56],{"_key":47,"_type":30,"marks":57,"text":58},[],"cumprir os requisitos aplicáveis aos produtos, serviços e atividades, incluindo requisitos de clientes, legais, regulamentares e outros que possam ser aplicáveis;",[],{"_key":61,"_type":26,"children":62,"level":50,"listItem":51,"markDefs":66,"style":34},"1c406c09087d",[63],{"_key":47,"_type":30,"marks":64,"text":65},[],"promover a excelência em todas as etapas, assegurando o controlo rigoroso, a consistência e a adequação técnica\ndesde a conceção e produção até à instalação final;",[],{"_key":68,"_type":26,"children":69,"level":50,"listItem":51,"markDefs":73,"style":34},"73771d8503fa",[70],{"_key":47,"_type":30,"marks":71,"text":72},[],"definir, monitorizar e rever os objetivos do sistema de gestão, de acordo com a nossa orientação estratégica;",[],{"_key":75,"_type":26,"children":76,"level":50,"listItem":51,"markDefs":80,"style":34},"aa654e74cd28",[77],{"_key":47,"_type":30,"marks":78,"text":79},[],"aplicar o pensamento baseado no risco e a tomada de decisão baseada em evidências, garantindo a resiliência e a eficácia do sistema de gestão;",[],{"_key":82,"_type":26,"children":83,"level":50,"listItem":51,"markDefs":87,"style":34},"f57e32fc728a",[84],{"_key":47,"_type":30,"marks":85,"text":86},[],"incentivar o desenvolvimento das pessoas, promovendo as suas competências, o espírito de iniciativa e uma cultura interna assente no compromisso, responsabilidade e melhoria contínua;",[],{"_key":89,"_type":26,"children":90,"level":50,"listItem":51,"markDefs":94,"style":34},"71ca2cc74e65",[91],{"_key":47,"_type":30,"marks":92,"text":93},[],"promover o envolvimento das pessoas nos objetivos globais e na participação da estratégia de crescimento;",[],{"_key":96,"_type":26,"children":97,"level":50,"listItem":51,"markDefs":101,"style":34},"53dc4aab96a9",[98],{"_key":47,"_type":30,"marks":99,"text":100},[],"promover a utilização responsável dos recursos, reduzindo desperdícios, minimizando o consumo de energia e valorizando o aproveitamento eficiente das matérias-primas utilizadas nos nossos processos;",[],{"_key":103,"_type":26,"children":104,"level":50,"listItem":51,"markDefs":108,"style":34},"f9a46a4ac44d",[105],{"_key":47,"_type":30,"marks":106,"text":107},[],"fortalecer relações de confiança e parceria com clientes, fornecedores e restantes parceiros, valorizando a cooperação estratégica e a criação de valor duradouro;",[],{"_key":110,"_type":26,"children":111,"level":50,"listItem":51,"markDefs":115,"style":34},"5f0530e3356d",[112],{"_key":47,"_type":30,"marks":113,"text":114},[],"monitorizar a satisfação do cliente, assegurando um tratamento ágil e eficaz de todas as reclamações e interações, utilizando a informação recolhida como motor de aprendizagem e aperfeiçoamento;",[],{"_key":117,"_type":26,"children":118,"level":50,"listItem":51,"markDefs":122,"style":34},"8b210f6d2594",[119],{"_key":47,"_type":30,"marks":120,"text":121},[],"melhorar continuamente a eficácia do sistema de gestão, otimizando os processos para potenciar o nosso\ndesempenho global.",[],{"_key":124,"_type":26,"children":125,"markDefs":130,"style":34},"e2ae2c46fd01",[126],{"_key":127,"_type":30,"marks":128,"text":129},"f38965628251",[],"A Gerência da Floema, Lda assegura os recursos necessários para concretizar esta política e compromete-se a comunicá-la, promovê-la e revê-la, para que continue viva, compreendida e aplicada em toda a nossa estrutura.",[],{"_key":132,"_type":22,"textBlock":133},"069e35988d3fa984ebf564bcf8a51720",[134,143,151],{"_key":135,"_type":26,"children":136,"markDefs":141,"style":142},"43137dbbadde",[137],{"_key":138,"_type":30,"marks":139,"text":140},"b6efaf54d599",[],"Contactos",[],"h3",{"_key":144,"_type":26,"children":145,"markDefs":150,"style":34},"4e2e6bfcc269",[146],{"_key":147,"_type":30,"marks":148,"text":149},"ffd70b9f9b54",[],"Para qualquer questão, pode contactar-nos através de:",[],{"_key":152,"_type":26,"children":153,"m