:97,"_type":98,"marks":99,"text":100},"b318b46c90b4","span",[],"O HPL sustenta a camada narrativa do território — o elemento que informa, orienta e interpreta, mantendo-se materialmente discreto e tecnicamente fiável.",[],"h3",{"_key":104,"_type":94,"children":105,"markDefs":110,"style":102},"50e1b32e5454",[106],{"_key":107,"_type":98,"marks":108,"text":109},"40f11e2ca865",[],"",[],{"_key":112,"_type":94,"children":113,"markDefs":119,"style":120},"c3a98e72d4f0",[114],{"_key":115,"_type":98,"marks":116,"text":118},"1e6bfc2c007d",[117],"strong","A resistência da comunicação",[],"h2",{"_key":122,"_type":94,"children":123,"markDefs":127,"style":128},"b2072c05fdc7",[124],{"_key":125,"_type":98,"marks":126,"text":109},"e45a0912d42d",[],[],"normal",{"_key":130,"_type":94,"children":131,"markDefs":136,"style":128},"15563004743b",[132],{"_key":133,"_type":98,"marks":134,"text":135},"31352943ca6f",[],"O High Pressure Laminate (HPL) é um material compósito estratificado desenvolvido para desempenho de longo prazo em ambientes exigentes e expostos. Constituído por camadas de fibras de celulose impregnadas com resinas termoendurecíveis e compactadas sob elevada pressão e temperatura, o HPL combina precisão superficial com estabilidade estrutural.",[],{"_key":138,"_type":94,"children":139,"markDefs":143,"style":128},"3d4d5342d765",[140],{"_key":141,"_type":98,"marks":142,"text":109},"82e8b8a16c2a",[],[],{"_key":145,"_type":94,"children":146,"markDefs":151,"style":128},"1cabfa079811",[147],{"_key":148,"_type":98,"marks":149,"text":150},"ef820ef13afa",[],"No ecossistema Floema, o HPL é utilizado sobretudo como material gráfico de construção para sinalética e componentes interpretativos. A sua estabilidade dimensional, resistência às intempéries e capacidade de manter cor e imagem ao longo do tempo permitem-lhe complementar o plástico reciclado e o metal em sistemas construtivos, equipamentos e infraestruturas de comunicação pública.\n\nVantagens: ",[],{"_key":153,"_type":94,"children":154,"level":87,"listItem":159,"markDefs":160,"style":128},"442969714953",[155],{"_key":156,"_type":98,"marks":157,"text":158},"0e4f8c46bead",[],"Material ideal para produção de sinalética e equipamentos;","bullet",[],{"_key":162,"_type":94,"children":163,"level":87,"listItem":159,"markDefs":168,"style":128},"8c02a4906f66",[164],{"_key":165,"_type":98,"marks":166,"text":167},"77aaac9bc508",[],"Alta durabilidade e resistência aos raios UV, água, gelo, fogo e variações térmicas;",[],{"_key":170,"_type":94,"children":171,"level":87,"listItem":159,"markDefs":176,"style":128},"b235cf6675ca",[172],{"_key":173,"_type":98,"marks":174,"text":175},"efdbb4e500d7",[],"Propriedades anti-apodrecimento e anti-graffiti;",[],{"_key":178,"_type":94,"children":179,"level":87,"listItem":159,"markDefs":184,"style":128},"687b559728bd",[180],{"_key":181,"_type":98,"marks":182,"text":183},"487932c0a713",[],"Resistência ao impacto e à abrasão;",[],{"_key":186,"_type":94,"children":187,"level":87,"listItem":159,"markDefs":192,"style":128},"3600e05baee2",[188],{"_key":189,"_type":98,"marks":190,"text":191},"4ffcb560a1e4",[],"Versatilidade de cores, acabamentos e espessuras;",[],{"_key":194,"_type":94,"children":195,"level":87,"listItem":159,"markDefs":200,"style":128},"da940a6b9f55",[196],{"_key":197,"_type":98,"marks":198,"text":199},"2f96379b344e",[],"Certificação PEFC;",[],{"_key":202,"_type":94,"children":203,"level":87,"listItem":159,"markDefs":208,"style":128},"1bfa58855ffc",[204],{"_key":205,"_type":98,"marks":206,"text":207},"a5c52f10cba2",[],"Sem necessidade de manutenção. ",[],{"_key":210,"_type":211,"caption":212,"mediaAsset":213},"e804978e18f7","figure","Totem direcional urbano personalizado em HPL+",[214],{"alt":215,"extension":11,"height":50,"hotspot":8,"type":13,"uid":216,"url":217,"width":53},"Detalhe de totem direcional em HPL+ para a Universidade católica portuguesa. Sinalética urbana personalizada da Floema Urban","e5cb239667ef","https://cdn.sanity.io/images/535lnz3g/production/81c43464b7319bd750948891e03e661bbea9cf1c-2152x1435.jpg",{"_key":219,"_type":220,"content":221,"sideLabel":238,"title":239},"c1fbe4a73e86","richBlockSideText",[222,230],{"_key":223,"_type":94,"children":224,"markDefs":229,"style":128},"5c284e0df297",[225],{"_key":226,"_type":98,"marks":227,"text":228},"4ca051ef01b3",[],"O HPL+ é a interpretação própria da Floema do HPL de alto desempenho para sinalética. Combina gravação CNC e laser com um sistema de pintura em poliuretano bicomponente, criando camadas de informação permanentemente integradas no material, em vez de gráficos aplicados à superfície.",[],{"_key":231,"_type":94,"children":232,"markDefs":237,"style":128},"103265655314",[233],{"_key":234,"_type":98,"marks":235,"text":236},"aaa7c033b0dd",[],"Esta técnica, desenvolvida e aperfeiçoada pela Floema, transforma o HPL num material de informação gravada, onde textos, símbolos e cartografia ficam fisicamente incorporados no painel. ",[],"Técnica de produção especializada e de alta qualidade","HPL+ - informação gravada, feita para durar",{"_key":241,"_type":242,"figures":243,"variant":256},"2d796542a17f","figureSet",[244,250],{"_key":245,"_type":211,"mediaAsset":246},"908f680935a5",[247],{"alt":248,"extension":11,"height":12,"hotspot":8,"type":13,"uid":249,"url":15,"width":16},"Detalhe de CNC a gravar HPL para a produção HPL+.","af09be5a8328",{"_key":251,"_type":211,"mediaAsset":252},"ae5d696a313f",[253],{"alt":254,"extension":11,"height":12,"hotspot":8,"type":13,"uid":255,"url":31,"width":16},"Diretório de encaminhamento ","12de88d0d330","variant1",{"_key":258,"_type":220,"content":259,"sideLabel":283,"title":284},"71c4b332d928",[260,268,275],{"_key":261,"_type":94,"children":262,"markDefs":267,"style":128},"af502e9469c7",[263],{"_key":264,"_type":98,"marks":265,"text":266},"54dd4185a619",[],"O HPL+ foi desenvolvido para responder a um desafio recorrente da sinalética exterior: a perda progressiva de informação causada pela exposição UV, humidade, abrasão e vandalismo. Ao gravar a informação no próprio material, elimina-se a fragilidade de películas, tintas ou adesivos superficiais.",[],{"_key":269,"_type":94,"children":270,"markDefs":274,"style":128},"bd31f736fc76",[271],{"_key":272,"_type":98,"marks":273,"text":109},"09c59cce7553",[],[],{"_key":276,"_type":94,"children":277,"markDefs":282,"style":128},"4d8e0c39e32e",[278],{"_key":279,"_type":98,"marks":280,"text":281},"9a12b580ddb6",[],"O resultado é um material de sinalética que mantém legibilidade, estabilidade cromática e clareza gráfica sob exposição contínua.",[],"Para legibilidade contínua no exterior","Informação duradoura",{"_key":286,"_type":211,"caption":287,"mediaAsset":288},"93e3b65b625f","Placa de encaminhamento personalizada.",[289],{"alt":290,"extension":11,"height":12,"hotspot":8,"type":13,"uid":291,"url":292,"width":16},"Placa de encaminhamento para hotel personalizada com informação em HPL+ e base em aço corten.","0ed9fba468a6","https://cdn.sanity.io/images/535lnz3g/production/80a7f9dff67f153c153f05c757f64c4366ed47b6-2096x2182.jpg",{"_key":294,"_type":220,"content":295,"sideLabel":352,"title":353},"0d17e7fdba84",[296,304,312,320,328,336,344],{"_key":297,"_type":94,"children":298,"markDefs":303,"style":128},"268c256bb7cf",[299],{"_key":300,"_type":98,"marks":301,"text":302},"3e37b3ba455a",[],"O HPL+ apresenta elevada resistência a:",[],{"_key":305,"_type":94,"children":306,"level":87,"listItem":159,"markDefs":311,"style":128},"404b4ae515e3",[307],{"_key":308,"_type":98,"marks":309,"text":310},"e94dbc8740a5",[],"Radiação UV",[],{"_key":313,"_type":94,"children":314,"level":87,"listItem":159,"markDefs":319,"style":128},"7c983eeaf1b5",[315],{"_key":316,"_type":98,"marks":317,"text":318},"2a5a9b99d34b",[],"Humidade, chuva e imersão total em água",[],{"_key":321,"_type":94,"children":322,"level":87,"listItem":159,"markDefs":327,"style":128},"68f42ed0c9cc",[323],{"_key":324,"_type":98,"marks":325,"text":326},"c619b55c734d",[],"Condições de gelo e variações térmicas",[],{"_key":329,"_type":94,"children":330,"level":87,"listItem":159,"markDefs":335,"style":128},"da17fd9b8fad",[331],{"_key":332,"_type":98,"marks":333,"text":334},"7293955de4a6",[],"Impacto e abrasão",[],{"_key":337,"_type":94,"children":338,"level":87,"listItem":159,"markDefs":343,"style":128},"5f9b88d74b6e",[339],{"_key":340,"_type":98,"marks":341,"text":342},"87bbab08626c",[],"Graffiti e alterações superficiais",[],{"_key":345,"_type":94,"children":346,"markDefs":351,"style":128},"4573a722b26b",[347],{"_key":348,"_type":98,"marks":349,"text":350},"d36795127de7",[],"As zonas gravadas são acabadas com tinta poliuretano bicomponente, garantindo estabilidade cromática e proteção de longo prazo. O material não apodrece, não incha nem se degrada, mantendo continuidade estrutural e visual.",[],"Um alto rendimento que testa as exigências dos espaços","Um material que resiste",{"_key":355,"_type":211,"author":356,"caption":357,"mediaAsset":358},"cca9fb0d6b2a","Fotografia de Bruno Lima","Placa direcional de percursos pedestres",[359],{"alt":360,"extension":11,"height":361,"hotspot":8,"type":13,"uid":362,"url":363,"width":364},"Placa direcional para percursos pedestres com poste em plástico reciclado da Floema, num parque natural cheio de neve.",1333,"1eacae58ea3d","https://cdn.sanity.io/images/535lnz3g/production/a63f69e8cfa468b275881566f5f797a928c801be-2000x1333.jpg",2000,{"_key":366,"_type":220,"content":367,"sideLabel":392,"title":393},"c115e977ee2b",[368,376,384],{"_key":369,"_type":94,"children":370,"markDefs":375,"style":128},"4bb5b50c47f3",[371],{"_key":372,"_type":98,"marks":373,"text":374},"65265531ad51",[],"Na lógica construtiva da Floema, o HPL+ não substitui a estrutura — completa-a.",[],{"_key":377,"_type":94,"children":378,"markDefs":383,"style":128},"671e8330330e",[379],{"_key":380,"_type":98,"marks":381,"text":382},"0c4e5ada20d1",[],"Introduz informação, orientação e interpretação em sistemas construídos com plástico reciclado e metal, formando infraestruturas de comunicação pública coerentes e duráveis.",[],{"_key":385,"_type":94,"children":386,"markDefs":391,"style":128},"056a1108d6ec",[387],{"_key":388,"_type":98,"marks":389,"text":390},"509a6c09b314",[],"Onde o plástico reciclado garante resistência estrutural e o metal define o ritmo espacial, o HPL introduz a camada narrativa — precisa, estável e discretamente integrada no território.",[],"Além da comunicação - continuidade construtiva","Um material que completa a estrutura",{"_key":395,"_type":211,"caption":396,"mediaAsset":397},"cb938be98099","Bike station Plaza",[398],{"alt":399,"extension":11,"height":50,"hotspot":8,"type":13,"uid":400,"url":401,"width":53},"Bike station urbana modelo Floema em aço inoxidável pintado e com informação em HPL+","477257d4db62","https://cdn.sanity.io/images/535lnz3g/production/89646069893c70367ddf8af41d35b55ab0815887-2152x1435.jpg",{"_key":403,"_type":220,"content":404,"sideLabel":436,"title":437},"f789b506c45e",[405,413,421,428],{"_key":406,"_type":94,"children":407,"markDefs":412,"style":128},"26a067e81c9e",[408],{"_key":409,"_type":98,"marks":410,"text":411},"d9f847926db3",[],"Disponível numa ampla diversidade de cores e texturas — incluindo tons sólidos, efeitos metálicos e acabamentos que evocam madeira — o HPL+ adapta-se a diferentes contextos territoriais mantendo uma presença visual contida.",[],{"_key":414,"_type":94,"children":415,"markDefs":420,"style":128},"33e240945eb1",[416],{"_key":417,"_type":98,"marks":418,"text":419},"5b16992c0790",[],"Os painéis HPL+ podem ser produzidos com gravação numa ou em ambas as faces, para uso interior ou exterior. Apresentam baixo coeficiente de dilatação e estão disponíveis em espessuras de 6, 8, 10 e 13 mm, com densidade aproximada de 1,35 g/cm³.",[],{"_key":422,"_type":94,"children":423,"markDefs":427,"style":128},"13907b7f5bbf",[424],{"_key":425,"_type":98,"marks":426,"text":109},"89517e324d6b",[],[],{"_key":429,"_type":94,"children":430,"markDefs":435,"style":128},"bcad1522c1ef",[431],{"_key":432,"_type":98,"marks":433,"text":434},"e99654366ada",[],"A matéria-prima é certificada PEFC, assegurando gestão responsável dos recursos florestais.",[],"Versatilidade e certificação","Enquadramento técnico",{"_key":439,"_type":220,"content":440,"sideLabel":457,"title":458},"f14b26c6a76f",[441,449],{"_key":442,"_type":94,"children":443,"markDefs":448,"style":128},"e7e13d6c5e4e",[444],{"_key":445,"_type":98,"marks":446,"text":447},"b7e700d20cfd",[],"O HPL Print é um painel laminado estratificado que integra imagem digital de alta definição no interior da sua estrutura. Ao contrário de impressões aplicadas à superfície, a imagem passa a fazer parte do próprio material, garantindo qualidade visual permanente em ambientes expostos.",[],{"_key":450,"_type":94,"children":451,"markDefs":456,"style":128},"e208dcf984ad",[452],{"_key":453,"_type":98,"marks":454,"text":455},"bf0db95544b9",[],"Esta solução destina-se a sinalética interpretativa, educativa e expositiva onde a riqueza visual, a reprodução fotográfica e a profundidade cromática são essenciais.",[],"Impressão digital estratificada com a melhor qualidade de imagem do mercado","HPL Print - riqueza visual, estabilidade permanente da imagem",{"_key":460,"_type":211,"mediaAsset":461},"deac7f91a76d",[462],{"alt":463,"extension":11,"height":62,"hotspot":8,"type":13,"uid":464,"url":465,"width":65},"Painel informativo grande ICNF com estrutura em plástico reciclado e painel em HPL Print, modelo Floema, integrado no parque natural da Serra da Estrela.","c89f5d6b40f4","https://cdn.sanity.io/images/535lnz3g/production/81bfe50fdb08d14c4868e02010acfee39e0cf455-4304x2870.jpg",{"_key":467,"_type":220,"content":468,"sideLabel":547,"title":548},"b0d5a2f6a911",[469,477,485,493,501,509,517,524,532,539],{"_key":470,"_type":94,"children":471,"markDefs":476,"style":128},"39140585b6fd",[472],{"_key":473,"_type":98,"marks":474,"text":475},"e77462456d9a",[],"O HPL Print mantém:",[],{"_key":478,"_type":94,"childre