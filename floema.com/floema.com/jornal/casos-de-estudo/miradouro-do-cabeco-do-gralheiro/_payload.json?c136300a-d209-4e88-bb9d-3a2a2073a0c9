[{"data":1,"prerenderedAt":231},["ShallowReactive",2],{"sanity-VfIRCao1bY":3},{"_type":4,"gallery":5,"metadata":47,"sections":54},"page.article",{"images":6,"title":46},[7,17,24,29,34,39],{"description":8,"mediaAsset":9},null,[10],{"alt":8,"extension":11,"height":12,"hotspot":8,"type":13,"uid":14,"url":15,"width":16},"jpg",1435,"image","4fdf211fbc91","https://cdn.sanity.io/images/535lnz3g/production/9dd2d855f58788ce0ebd7f15cabf9bdc3df93bf4-2152x1435.jpg",2152,{"description":8,"mediaAsset":18},[19],{"alt":8,"extension":11,"height":20,"hotspot":8,"type":13,"uid":21,"url":22,"width":23},666,"c346083b7e3a","https://cdn.sanity.io/images/535lnz3g/production/8dc546b0516ccd1060938731b35a41f262992b76-1000x666.jpg",1000,{"description":8,"mediaAsset":25},[26],{"alt":8,"extension":11,"height":12,"hotspot":8,"type":13,"uid":27,"url":28,"width":16},"19ffe62e7729","https://cdn.sanity.io/images/535lnz3g/production/b56774345d0c2292c26d873ea5860b65c272949c-2152x1435.jpg",{"description":8,"mediaAsset":30},[31],{"alt":8,"extension":11,"height":12,"hotspot":8,"type":13,"uid":32,"url":33,"width":16},"c675acc8ed6b","https://cdn.sanity.io/images/535lnz3g/production/21bdac264f38c54ae7068cf03f5708714a274487-2152x1435.jpg",{"description":8,"mediaAsset":35},[36],{"alt":8,"extension":11,"height":12,"hotspot":8,"type":13,"uid":37,"url":38,"width":16},"5c0098401b4a","https://cdn.sanity.io/images/535lnz3g/production/9e0926881453f613052483f35db2a357715dc9d6-2152x1435.jpg",{"description":8,"mediaAsset":40},[41],{"alt":8,"extension":11,"height":42,"hotspot":8,"type":13,"uid":43,"url":44,"width":45},1333,"783ab780cf0d","https://cdn.sanity.io/images/535lnz3g/production/60633edc71ae17abeb09e15ec5f83849d049233a-2000x1333.jpg",2000,"Ecodesign que potencia",{"description":48,"image":8,"keywords":49,"sitedescription":50,"sitename":51,"slug":52,"title":53},"Miradouro no percurso pedestre PR8 da Serra da Freita, projetado e instalado pela Floema em plástico reciclado, com bancos e mesa interpretativa integrados num ecossistema natural sensível.","miradouro plástico reciclado, serra da freita, percurso pr8, ecoturismo, infraestruturas naturais, sinalética interpretativa, floema","Descripción de Floema","Site Floema","miradouro-do-cabeco-do-gralheiro","Miradouro do Cabeço do Gralheiro | Plástico Reciclado | Floema",[55,70],{"_type":56,"category":57,"date":8,"figure":60,"readTime":68,"title":69},"articleHeader",{"name":58,"slug":59},"Casos de Estudo","casos-de-estudo",{"_type":13,"author":61,"caption":62,"mediaAsset":63},"Floema","Caption",[64],{"alt":65,"extension":11,"height":42,"hotspot":8,"type":13,"uid":66,"url":67,"width":45},"Miradouro em plástico reciclado da Floema.","53c2a0cebcc2","https://cdn.sanity.io/images/535lnz3g/production/fc104e98e92557f6e00ddd2a8f95f1d58b1e4d25-2000x1333.jpg",1,"Miradouro do Cabeço do Gralheiro",{"_type":71,"content":72,"readingTime":68,"type":4},"articleContent",[73,84,93,101,108,117,125,133,140,147,168,173,193,198,226],{"_key":74,"_type":75,"children":76,"markDefs":82,"style":83},"778c83c34033","block",[77],{"_key":78,"_type":79,"marks":80,"text":81},"e00d81e5f4b4","span",[],"O miradouro do Cabeço do Gralheiro nasce na encosta sul da Serra da Freita, integrado no percurso pedestre PR8. Um território de elevada sensibilidade ecológica, onde a leitura da paisagem, a contenção da intervenção e a durabilidade das soluções são determinantes.",[],"h4",{"_key":85,"_type":75,"children":86,"markDefs":91,"style":92},"c8ba8ce936c9",[87],{"_key":88,"_type":79,"marks":89,"text":90},"b2bc3b90a6dc",[],"",[],"normal",{"_key":94,"_type":75,"children":95,"markDefs":100,"style":92},"124fc3b63c27",[96],{"_key":97,"_type":79,"marks":98,"text":99},"e8752cec2b54",[],"O desafio consistiu em criar um ponto de observação que permitisse a contemplação e interpretação do território sem comprometer o equilíbrio do ecossistema envolvente. Um projeto onde a infraestrutura não se impõe à paisagem, mas a revela.",[],{"_key":102,"_type":75,"children":103,"markDefs":107,"style":92},"6b201732866e",[104],{"_key":105,"_type":79,"marks":106,"text":90},"6f9f6b4d2143",[],[],{"_key":109,"_type":75,"children":110,"markDefs":115,"style":116},"c3a98e72d4f0",[111],{"_key":112,"_type":79,"marks":113,"text":114},"c57675c5fa05",[],"Infraestrutura como ferramenta de preservação ",[],"h2",{"_key":118,"_type":75,"children":119,"markDefs":124,"style":92},"5b5167f6fcea",[120],{"_key":121,"_type":79,"marks":122,"text":123},"d7bd9158de88",[],"Em áreas naturais sensíveis, a criação de miradouros deve responder a uma dupla exigência: oferecer condições de fruição e, simultaneamente, proteger o território do uso disperso e desordenado.",[],{"_key":126,"_type":75,"children":127,"markDefs":132,"style":92},"155432e3ea9a",[128],{"_key":129,"_type":79,"marks":130,"text":131},"61cfd8f10a4e",[],"A intervenção no Cabeço do Gralheiro foi pensada para concentrar a presença humana num ponto definido, reduzindo o pisoteio fora do trilho e preservando solos, vegetação e habitats envolventes. O miradouro atua, assim, como infraestrutura de contenção e orientação, integrada no percurso pedestre existente.",[],{"_key":134,"_type":75,"children":135,"markDefs":139,"style":92},"3b4979667018",[136],{"_key":137,"_type":79,"marks":138,"text":90},"ad42b2a9a441",[],[],{"_key":141,"_type":142,"caption":143,"mediaAsset":144},"64a3a0597ae9","figure","Miradouro em plástico reciclado",[145],{"alt":8,"extension":11,"height":12,"hotspot":8,"type":13,"uid":146,"url":15,"width":16},"3c94e2e423f4",{"_key":148,"_type":149,"content":150,"title":167},"71c4b332d928","richBlockSideText",[151,159],{"_key":152,"_type":75,"children":153,"markDefs":158,"style":92},"73a9fc3fea47",[154],{"_key":155,"_type":79,"marks":156,"text":157},"739353403231",[],"O projeto e a instalação do miradouro foram integralmente realizados em plástico reciclado. A escolha deste material responde diretamente às exigências do local: exposição permanente às intempéries, variações térmicas, humidade e ausência de manutenção.",[],{"_key":160,"_type":75,"children":161,"markDefs":166,"style":92},"b461790fdba9",[162],{"_key":163,"_type":79,"marks":164,"text":165},"f6e9694c3abc",[],"O plástico reciclado oferece elevada durabilidade, resistência à água, ao gelo e à radiação UV, mantendo estabilidade estrutural e cromática ao longo do tempo. A inexistência de apodrecimento, fissuração ou corrosão torna-o particularmente adequado para espaços naturais onde a intervenção humana futura deve ser mínima.",[],"Plástico reciclado como material estrutural",{"_key":169,"_type":142,"mediaAsset":170},"93e3b65b625f",[171],{"alt":8,"extension":11,"height":12,"hotspot":8,"type":13,"uid":172,"url":28,"width":16},"d54c68f06f03",{"_key":174,"_type":149,"content":175,"title":192},"0d17e7fdba84",[176,184],{"_key":177,"_type":75,"children":178,"markDefs":183,"style":92},"8c72d5c48611",[179],{"_key":180,"_type":79,"marks":181,"text":182},"e557294579e7",[],"Ao miradouro foram integrados dois bancos e uma mesa interpretativa, igualmente produzidos em plástico reciclado. Estes elementos criam um espaço de pausa ao longo do percurso, convidando à observação, ao descanso e à leitura da paisagem.",[],{"_key":185,"_type":75,"children":186,"markDefs":191,"style":92},"afa4dd96724e",[187],{"_key":188,"_type":79,"marks":189,"text":190},"f137a5a65828",[],"A mesa interpretativa explora o território envolvente, promovendo uma experiência educativa e de sensibilização ambiental. Mais do que um ponto de chegada, o miradouro torna-se um lugar de compreensão do espaço natural e das suas dinâmicas.",[],"Um ponto de pausa leitura e interpretação",{"_key":194,"_type":142,"mediaAsset":195},"c34b73218b23",[196],{"alt":8,"extension":11,"height":12,"hotspot":8,"type":13,"uid":197,"url":33,"width":16},"cd423d1ae81e",{"_key":199,"_type":149,"content":200,"title":225},"c115e977ee2b",[201,209,217],{"_key":202,"_type":75,"children":203,"markDefs":208,"style":92},"585ac4c06376",[204],{"_key":205,"_type":79,"marks":206,"text":207},"2ff42ed66137",[],"A intervenção no Cabeço do Gralheiro reforça o valor do percurso PR8, qualificando a experiência do caminhar sem descaracterizar o lugar.\nA infraestrutura permite que o visitante observe, compreenda e respeite a paisagem, ao mesmo tempo que contribui para a proteção do ecossistema.",[],{"_key":210,"_type":75,"children":211,"markDefs":216,"style":92},"9da4d9a82209",[212],{"_key":213,"_type":79,"marks":214,"text":215},"6efa3f041cc6",[],"Desenvolvido e instalado pela Floema, o miradouro do Cabeço do Gralheiro afirma-se como um exemplo de como o desenho, o material e a leitura do território podem convergir numa solução durável, funcional e ambientalmente responsável.",[],{"_key":218,"_type":75,"children":219,"markDefs":224,"style":92},"92751525f363",[220],{"_key":221,"_type":79,"marks":222,"text":223},"1757f882d5fd",[],"Um projeto onde o plástico reciclado não é apenas um material — é um instrumento de preservação, educação e fruição consciente da paisagem.",[],"Potenciar o percurso e valorizar o território",{"_key":227,"_type":142,"mediaAsset":228},"18dae892f67b",[229],{"alt":8,"extension":11,"height":20,"hotspot":8,"type":13,"uid":230,"url":22,"width":23},"33c0b3e96cb9",1783610847565]