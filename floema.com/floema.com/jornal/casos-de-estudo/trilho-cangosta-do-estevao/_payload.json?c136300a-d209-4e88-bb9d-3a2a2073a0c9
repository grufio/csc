":85,"children":96,"markDefs":101,"style":102},"52e29514e226",[97],{"_key":98,"_type":89,"marks":99,"text":100},"8e71ede81fd7",[],"",[],"normal",{"_key":104,"_type":85,"children":105,"markDefs":145,"style":102},"7e63ca9bda9b",[106,110,115,119,123,127,132,136,141],{"_key":107,"_type":89,"marks":108,"text":109},"fa0c870eefcb",[],"Este ",{"_key":111,"_type":89,"marks":112,"text":114},"940f6a5b8296",[113],"strong","projeto de sinalética urbana",{"_key":116,"_type":89,"marks":117,"text":118},"f2a6e96a8703",[]," ",{"_key":120,"_type":89,"marks":121,"text":122},"eabc791681c1",[113],"para o Trilho da Cangosta do Estêvão",{"_key":124,"_type":89,"marks":125,"text":126},"32a53f67c845",[],", reuniu diferentes entidades que cooperaram a nível de design da sinalética. Juntamente com a ",{"_key":128,"_type":89,"marks":129,"text":131},"87e462a8ac8f",[130],"38dc62366427","Câmara Municipal de Vila Nova de Famalicão",{"_key":133,"_type":89,"marks":134,"text":135},"a6b06d411643",[],", a Casa de Camilo – Museu | Centro de Estudos, e a empresa ",{"_key":137,"_type":89,"marks":138,"text":140},"2059c8ce61e9",[139],"5ea3d9c5ae64","Razão",{"_key":142,"_type":89,"marks":143,"text":144},"6ae963b91345",[],", a Floema® produziu e instalou toda a sinalética urbana personalizada para o trilho. ",[146,150],{"_key":130,"_type":147,"href":148,"linkType":149,"to":14},"link","https://www.cm-vnfamalicao.pt/","external",{"_key":139,"_type":147,"href":151,"linkType":149,"to":14},"https://razao.com.pt/",{"_key":153,"_type":85,"children":154,"markDefs":158,"style":102},"1f356decfb6a",[155],{"_key":156,"_type":89,"marks":157,"text":100},"1855a2003030",[],[],{"_key":160,"_type":85,"children":161,"markDefs":166,"style":93},"70a449fe69e8",[162],{"_key":163,"_type":89,"marks":164,"text":165},"75f0456c937b",[],"Sinalética informativa",[],{"_key":168,"_type":169,"figures":170,"variant":189},"a6d258864370","figureSet",[171,182],{"_key":172,"_type":173,"caption":174,"mediaAsset":175},"56d2640b9811","figure","Mesa interpretativa urbana personalizada, produzida em aço corten e HPL+.",[176],{"alt":177,"extension":12,"height":178,"hotspot":14,"type":15,"uid":179,"url":180,"width":181},"Homem a ler conteúdo de mesa interpretativa personalizada de monumento inserido em rota urbana, produzida em aço corten e HPL+.",2182,"62f12011776c","https://cdn.sanity.io/images/535lnz3g/production/ae8cbd6a1bef8aa2e0db62058c30cc386024c752-2096x2182.jpg",2096,{"_key":183,"_type":173,"mediaAsset":184},"acac1f216b34",[185],{"alt":186,"extension":12,"height":178,"hotspot":14,"type":15,"uid":187,"url":188,"width":181},"Detail of an urban route logo engraved on a Frame information totem, Floema model, with a corten steel structure and HPL+ panel.","09b7b651af66","https://cdn.sanity.io/images/535lnz3g/production/025dac3aad7660829d197f39f1b7cc28cbf814ad-2096x2182.jpg","variante1",{"_key":191,"_type":85,"children":192,"markDefs":197,"style":102},"780f4910e722",[193],{"_key":194,"_type":89,"marks":195,"text":196},"a50101e1eb78",[],"A sinalética informativa organiza os pontos de leitura do percurso. Introduz mapas, conteúdos patrimoniais e enquadramento literário. Estes suportes ajudam o visitante a compreender o território que percorre. Reforçam a dimensão cultural do trilho e promovem uma leitura contínua da paisagem construída.",[],{"_key":199,"_type":85,"children":200,"markDefs":204,"style":102},"3cfc2ff72ccc",[201],{"_key":202,"_type":89,"marks":203,"text":100},"46ff3df05bde",[],[],{"_key":206,"_type":85,"children":207,"markDefs":212,"style":213},"cb2d7781abde",[208],{"_key":209,"_type":89,"marks":210,"text":211},"ebda2d3de203",[],"Totens informativos",[],"h4",{"_key":215,"_type":173,"caption":216,"mediaAsset":217},"f21c9416b3c2","Totem informativo Frame em aço corten",[218],{"alt":219,"extension":12,"height":75,"hotspot":14,"type":15,"uid":220,"url":221,"width":78},"Totem informativo Frame, da Floema, com estrutura em aço corten e painel em HPL+ encostado a muro de pedra em ambiente rural.","a055b458419d","https://cdn.sanity.io/images/535lnz3g/production/25471fc09b553ab2455582bf7147abe0209c44d1-2152x1435.jpg",{"_key":223,"_type":85,"children":224,"markDefs":229,"style":102},"af4d5785fd12",[225],{"_key":226,"_type":89,"marks":227,"text":228},"7b921466f89a",[],"Os totens informativos Frame servem de suporte ao enquadramento patrimonial. Instalados em pontos estratégicos ao longo do trilho, estabelecem uma leitura do património cultural e edificado. São produzidos com estrutura em aço corten e painéis em HPL+, com informação gravada por CNC/laser e acabamento em tinta poliuretano bicomponente.",[],{"_key":231,"_type":85,"children":232,"markDefs":236,"style":102},"cbde953f26c1",[233],{"_key":234,"_type":89,"marks":235,"text":100},"a968a8199954",[],[],{"_key":238,"_type":85,"children":239,"markDefs":244,"style":213},"24de7f15cb89",[240],{"_key":241,"_type":89,"marks":242,"text":243},"81fc16b125a3",[],"Mesas interpretativas Frame",[],{"_key":246,"_type":173,"caption":71,"mediaAsset":247},"31fb5a90fd77",[248],{"alt":249,"extension":12,"height":75,"hotspot":14,"type":15,"uid":250,"url":251,"width":78},"Mesa interpretativa Frame em aço corten e com painel em HPL+ do Trilho da Cangosta do Estêvão.","41be8b3ccdc8","https://cdn.sanity.io/images/535lnz3g/production/38e7bea535d10b00ca5985ffda5e85b29af27897-2152x1435.jpg",{"_key":253,"_type":85,"children":254,"markDefs":259,"style":102},"abdae65ebf2a",[255],{"_key":256,"_type":89,"marks":257,"text":258},"ce65c9d97c63",[],"As mesas interpretativas Frame acompanham o percurso em pontos estratégicos, apresentando o mapa da rota urbana e os respetivos pontos de interesse. Esta comunicação é essencial para introduzir o visitante no universo do trilho e antecipar a riqueza do património edificado e das referências literárias associadas a Camilo Castelo Branco.",[],{"_key":261,"_type":85,"children":262,"markDefs":267,"style":102},"a0962a6cdc42",[263],{"_key":264,"_type":89,"marks":265,"text":266},"225aa939a5c2",[],"Com estrutura em aço corten e informação em HPL+, estes suportes conjugam a estética rústica do espaço com legibilidade contínua e resistência às intempéries.",[],{"_key":269,"_type":85,"children":270,"markDefs":274,"style":102},"e03b3e3f71fa",[271],{"_key":272,"_type":89,"marks":273,"text":100},"3e3bb40db9eb",[],[],{"_key":276,"_type":85,"children":277,"markDefs":282,"style":213},"dd722aa1a6f1",[278],{"_key":279,"_type":89,"marks":280,"text":281},"d9e3247f3cc1",[],"Mesas interpretativas personalizadas",[],{"_key":284,"_type":169,"figures":285,"variant":189},"595dc9ba07a5",[286,294],{"_key":287,"_type":173,"caption":288,"mediaAsset":289},"9d7cb129c14a","Mesa personalizada em aço corten para rota urbana",[290],{"alt":291,"extension":12,"height":178,"hotspot":14,"type":15,"uid":292,"url":293,"width":181},"Mesa interpretativa personalizada para o trilho da Cangosta do Estêvão em aço corten e painel em HPL+.","aed66973bbcc","https://cdn.sanity.io/images/535lnz3g/production/b2513c39c929bf53c8d69c4e05cb6103914a7776-2096x2182.jpg",{"_key":295,"_type":173,"mediaAsset":296},"ad61a11e85c1",[297],{"alt":298,"extension":12,"height":178,"hotspot":14,"type":15,"uid":299,"url":300,"width":181},"Mesa interpretativa personalizada para percurso urbano, produzida em aço corten, com o logótipo Cassa de Camilo recortado a laser na estrutura e informação num painel HPL+ Floema.","649d342413ec","https://cdn.sanity.io/images/535lnz3g/production/b27aca661f55605b461da51437b7ddbd9c0aed3b-2096x2182.jpg",{"_key":302,"_type":85,"children":303,"markDefs":308,"style":102},"42009a66aad7",[304],{"_key":305,"_type":89,"marks":306,"text":307},"800626f7b333",[],"Em locais específicos, foram desenvolvidas mesas interpretativas com desenho personalizado, ajustadas à morfologia dos espaços urbanos e à relação com o edificado envolvente.",[],{"_key":310,"_type":85,"children":311,"markDefs":316,"style":102},"076b0d9419ca",[312],{"_key":313,"_type":89,"marks":314,"text":315},"5114457b2719",[],"Estas estruturas em aço corten integram painéis em HPL+ gravados por CNC/laser, mantendo coerência material e formal com o sistema global.",[],{"_key":318,"_type":85,"children":319,"markDefs":323,"style":102},"14b7e0466fc8",[320],{"_key":321,"_type":89,"marks":322,"text":100},"c73baa7e9365",[],[],{"_key":325,"_type":85,"children":326,"markDefs":331,"style":93},"a12d66971fac",[327],{"_key":328,"_type":89,"marks":329,"text":330},"27c0933bf82c",[],"Sinalética direcional",[],{"_key":333,"_type":173,"caption":334,"mediaAsset":335},"0d325a6cab8b","Totem informativo e placas direcionais Frame",[336],{"alt":337,"extension":12,"height":75,"hotspot":14,"type":15,"uid":338,"url":339,"width":78},"Totem interpretativo e totem direcional da linha Frame da Floema Urban do Trilho da Cangosta do Estêvão. Estruturas em aço corten e informação em HPL+ de alta durabilidade.","9515646d9830","https://cdn.sanity.io/images/535lnz3g/production/01f394e44c01d084843f7885eb13c700253cea74-2152x1435.jpg",{"_key":341,"_type":85,"children":342,"markDefs":347,"style":102},"eb596f561280",[343],{"_key":344,"_type":89,"marks":345,"text":346},"211240020cd2",[],"A sinalética direcional assegura a orientação ao longo do percurso. Garante clareza, continuidade e legibilidade nos diferentes troços urbanos e rústicos. Estes elementos acompanham o caminhar sem interferir com a leitura do espaço. Tornam o trajeto acessível e intuitivo.",[],{"_key":349,"_type":85,"children":350,"markDefs":354,"style":102},"efcf78c216c3",[351],{"_key":352,"_type":89,"marks":353,"text":100},"693bfa59b96b",[],[],{"_key":356,"_type":85,"children":357,"markDefs":362,"style":213},"736b73cbed10",[358],{"_key":359,"_type":89,"marks":360,"text":361},"c9730fda976a",[]," Postes e placas direcionais Frame",[],{"_key":364,"_type":173,"caption":365,"mediaAsset":366},"e4849198bc18","Placas direcionais Frame",[367],{"alt":368,"extension":12,"height":75,"hotspot":14,"type":15,"uid":369,"url":370,"width":78},"Detalhe de placas direcionais Frame da Floema Urban em HPL+ com sistema de fixação e poste Frame em aço corten.","300774b70574","https://cdn.sanity.io/images/535lnz3g/production/5352e8f94908cac9e8e09fe06caf00cef932e7bc-2152x1435.jpg",{"_key":372,"_type":85,"children":373,"markDefs":378,"style":102},"620501be0489",[374],{"_key":375,"_type":89,"marks":376,"text":377},"58fd765a75a6",[],"O sistema de encaminhamento é assegurado por postes e placas direcionais Frame em aço corten com painéis em HPL+.",[],{"_key":380,"_type":85,"children":381,"markDefs":386,"style":102},"0cc9a78612fa",[382],{"_key":383,"_type":89,"marks":384,"text":385},"d18c5c23fd85",[],"Em vários pontos ao longo do percurso, foram utilizados suportes pré-existentes para fixar a sinalética, reduzindo a introdução de novos elementos e preservando a perceção dos espaços urbanos e rurais envolventes. Noutros locais, a instalação de postes revelou-se necessária para garantir visibilidade, continuidade e uma orientação clara.",[],{"_key":388,"_type":85,"children":389,"markDefs":393,"style":102},"68568a6243c8",[390],{"_key":391,"_type":89,"marks":392,"text":100},"040ce7dfc90c",[],[],{"_key":395,"_type":85,"children":396,"markDefs":401,"style":93},"5ec3e69e257b",[397],{"_key":398,"_type":89,"marks":399,"text":400},"e56e3189cfe7",[],"Continuidade material e integração urbana",[],{"_key":403,"_type":169,"figures":404,"variant":189},"d64df68fd984",[405,413],{"_key":406,"_type":173,"caption":407,"mediaAsset":408},"fb2e1650b66c","Totem Frame S da Floema Urban em aço corten",[409],{"alt":410,"extension":12,"height":178,"hotspot":14,"type":15,"uid":411,"url":412,"width":181},"Detalhe de totem informativo Frame, da Floema Urban, para a rota urbana Trilho da Cangosta do Estêvão. Com informação em HPL+ e estrutura em aço corten.","3077664848cd","https://cdn.sanity.io/images/535lnz3g/production/ea4c81cee39dec2ea933b2175cb191a5866e5207-2096x2182.jpg",{"_key":414,"_type":173,"caption":415,"mediaAsset":416},"b1c2decdb261","Totem direcional urbano personalizado, em aço corten",[417],{"alt":418,