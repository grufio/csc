---
import { company } from '../data/site';
interface Props { text?: string; }
const { text = 'Von der Anfrage bis zur Auftragsabwicklung — wir unterstützen Sie bei Beschaffungsthemen jeder Komplexität.' } = Astro.props;
---

<section class="cta bg-dark">
  <div class="container-wide reveal">
    <p class="eyebrow">Kontakt</p>
    <div class="cta-row">
      <h2 class="h1 cta-title">Sprechen Sie<br />uns an.</h2>
      <div class="cta-side">
        <p class="lead">{text}</p>
        <div class="cta-actions">
          <a href="/kontakt" class="badge badge-acid">Kontakt aufnehmen</a>
          <a href={`mailto:${company.emails.sales}`} class="cta-mail">{company.emails.sales}</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta { padding-block: clamp(80px, 13vh, 160px); }
  .cta-row {
    margin-top: 24px;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: clamp(32px, 6vw, 96px);
    align-items: end;
  }
  .cta-title { color: var(--color-paper); }
  .cta-side { max-width: 44ch; }
  .cta-actions { margin-top: 28px; display: flex; align-items: center; gap: 28px; flex-wrap: wrap; }
  .cta-mail {
    font-size: 15px; color: var(--color-acid);
    border-bottom: 1px solid rgba(233,231,120,0.5); padding-bottom: 3px;
  }
  @media (max-width: 820px) {
    .cta-row { grid-template-columns: 1fr; gap: 32px; align-items: start; }
  }
</style>
