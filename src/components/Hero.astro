---
import { Image } from 'astro:assets';
import circuit from '../assets/images/circuit-board.jpg';
---

<section class="hero">
  <div class="container-wide">
    <h1 class="display hero-title reveal">
      Ihr Lieferant für <span class="hero-em">elektronische</span> Komponenten.
    </h1>

    <div class="hero-stage reveal">
      <figure class="hero-frame">
        <Image
          src={circuit}
          alt="Elektronische Leiterplatte mit integrierten Schaltkreisen"
          widths={[800, 1200, 1600, 2000]}
          sizes="100vw"
          loading="eager"
          class="hero-img"
        />
      </figure>

      <div class="hero-tagline">
        <p>Rethinking sourcing beyond expectations</p>
        <hr class="hairline" />
        <a href="#leistungen" class="hero-how">So arbeiten wir <span aria-hidden="true">↓</span></a>
      </div>

      <a href="/kontakt" class="hero-card">
        <span class="hero-card-text">Grosse Projekte beginnen mit einem guten Gespräch.</span>
        <span class="hero-card-cta"><span class="icon-circle" aria-hidden="true">✉</span> Kontakt aufnehmen</span>
      </a>
    </div>
  </div>
</section>

<style>
  .hero { padding-top: clamp(24px, 5vh, 64px); padding-bottom: clamp(40px, 7vh, 90px); }
  .hero-title { text-align: center; max-width: 20ch; margin-inline: auto; }
  .hero-em { font-style: italic; font-weight: 500; }

  .hero-stage { position: relative; margin-top: clamp(28px, 5vh, 64px); }
  .hero-frame { position: relative; margin: 0; border-radius: 22px; overflow: hidden; }
  .hero-img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; display: block; }
  .hero-frame::after {
    content: ""; position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(to top, rgba(10,20,16,0.55) 0%, rgba(10,20,16,0.12) 26%, transparent 48%);
  }

  .hero-tagline {
    position: absolute; left: clamp(20px, 3vw, 44px); bottom: clamp(20px, 3vw, 40px);
    max-width: 260px; color: var(--color-grey);
    text-shadow: 0 1px 20px rgba(0,0,0,0.35);
  }
  .hero-tagline p { font-size: 17px; line-height: 1.3; letter-spacing: -0.01em; }
  .hero-tagline .hairline { margin: 14px 0; border-color: rgba(236,234,227,0.4); }
  .hero-how { font-size: 13px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-grey); }

  .hero-card {
    position: absolute; right: clamp(20px, 3vw, 40px); bottom: clamp(20px, 3vw, 40px);
    width: min(320px, 72vw);
    background: rgba(28,28,26,0.62); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(236,234,227,0.18); border-radius: 18px; padding: 22px;
    color: var(--color-grey); display: flex; flex-direction: column; gap: 20px;
    transition: background-color 0.3s var(--ease);
  }
  .hero-card:hover { background: rgba(14,42,34,0.78); }
  .hero-card-text { font-size: 17px; line-height: 1.35; letter-spacing: -0.01em; }
  .hero-card-cta { display: inline-flex; align-items: center; gap: 12px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; }
  .hero-card .icon-circle { width: 40px; height: 40px; font-size: 15px; color: var(--color-grey); }

  @media (max-width: 760px) {
    .hero-img { aspect-ratio: 3 / 4; }
    .hero-tagline { display: none; }
    .hero-card { position: static; width: auto; margin-top: 14px; background: var(--color-green); }
  }
</style>
