---
import { Image } from 'astro:assets';
import circuit from '../assets/images/circuit-board.jpg';
import { company } from '../data/site';
---

<section class="hero">
  <div class="container-wide">
    <div class="hero-top">
      <p class="eyebrow reveal">Zürich · seit 1994</p>
      <h1 class="display hero-title reveal">
        Ihr Lieferant für <span class="accent">elektronische</span> Komponenten.
      </h1>
    </div>

    <div class="hero-meta reveal">
      <div class="hero-lead">
        <p class="lead">
          Ihr Ansprechpartner für elektronische Komponenten namhafter Hersteller —
          Beschaffung, Fertigungsdienstleistungen aus China und Supply-Chain-Management.
        </p>
        <div class="hero-actions">
          <a href="#leistungen" class="btn btn-primary">Leistungen</a>
          <a href="/kontakt" class="link-more">Kontakt aufnehmen</a>
        </div>
      </div>
      <div class="hero-index">
        <span class="label">Kompetenzen</span>
        <ul>
          <li>Komponenten</li>
          <li>Displays &amp; Touch</li>
          <li>Kabelkonfektion</li>
          <li>Supply Management</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="container-wide hero-media reveal">
    <figure class="hero-frame">
      <Image
        src={circuit}
        alt="Elektronische Leiterplatte mit integrierten Schaltkreisen"
        widths={[800, 1200, 1600, 2000]}
        sizes="100vw"
        loading="eager"
        class="hero-img"
      />
      <figcaption class="label hero-cap">Fig. 01 — Integrated Circuits</figcaption>
    </figure>
  </div>
</section>

<style>
  .hero { padding-top: clamp(48px, 8vh, 96px); }
  .hero-title { margin-top: 22px; max-width: 16ch; }
  .accent {
    background: var(--color-acid);
    box-shadow: 0.12em 0 0 var(--color-acid), -0.12em 0 0 var(--color-acid);
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }

  .hero-meta {
    margin-top: clamp(40px, 6vh, 72px);
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: clamp(32px, 6vw, 96px);
    align-items: end;
    padding-top: 32px;
    border-top: 1px solid var(--color-hairline);
  }
  .hero-lead { max-width: 46ch; }
  .hero-actions { margin-top: 30px; display: flex; align-items: center; gap: 28px; flex-wrap: wrap; }

  .hero-index ul { list-style: none; margin: 14px 0 0; padding: 0; }
  .hero-index li {
    font-size: 16px; color: var(--color-ink-soft);
    padding: 9px 0; border-top: 1px solid var(--color-hairline);
  }
  .hero-index li:first-of-type { border-top: none; }

  .hero-media { margin-top: clamp(48px, 8vh, 100px); }
  .hero-frame { margin: 0; }
  .hero-img { width: 100%; aspect-ratio: 21 / 9; object-fit: cover; }
  .hero-cap { margin-top: 14px; color: var(--color-muted); }

  @media (max-width: 800px) {
    .hero-meta { grid-template-columns: 1fr; gap: 40px; }
    .hero-img { aspect-ratio: 4 / 3; }
  }
</style>
