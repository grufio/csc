---
import { services } from '../data/site';
---

<section class="section" id="leistungen">
  <div class="container-wide">
    <div class="grid-head reveal">
      <p class="eyebrow">Leistungen</p>
      <h2 class="h2">Ein Partner für die<br />gesamte Beschaffung.</h2>
    </div>

    <ul class="index-list">
      {services.map((s, i) => (
        <li class="reveal">
          <a href={`/${s.slug}`} class="index-row">
            <span class="index-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="index-title">{s.title}</span>
            <span class="index-desc">{s.short}</span>
            <span class="index-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .grid-head { margin-bottom: clamp(48px, 7vh, 88px); }
  .grid-head .h2 { margin-top: 18px; }

  .index-list { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--color-hairline); }
  .index-row {
    display: grid;
    grid-template-columns: 64px minmax(220px, 1fr) minmax(0, 1.1fr) 40px;
    gap: 24px;
    align-items: baseline;
    padding: clamp(24px, 3vw, 40px) 8px;
    border-bottom: 1px solid var(--color-hairline);
    transition: padding-left 0.4s var(--ease), background-color 0.4s var(--ease);
  }
  .index-row:hover { padding-left: 24px; background: var(--color-paper-2); }
  .index-num { font-size: 13px; color: var(--color-muted); letter-spacing: 0.1em; padding-top: 8px; }
  .index-title {
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(22px, 2.6vw, 36px); line-height: 1.05; letter-spacing: -0.02em;
  }
  .index-desc { font-size: 16px; line-height: 1.45; color: var(--color-muted); }
  .index-arrow {
    justify-self: end; font-size: 22px; color: var(--color-ink);
    opacity: 0; transform: translateX(-8px);
    transition: opacity 0.4s var(--ease), transform 0.4s var(--ease);
  }
  .index-row:hover .index-arrow { opacity: 1; transform: none; }

  @media (max-width: 820px) {
    .index-row {
      grid-template-columns: 40px 1fr;
      gap: 6px 16px;
    }
    .index-num { padding-top: 6px; }
    .index-desc { grid-column: 2; }
    .index-arrow { display: none; }
  }
</style>
