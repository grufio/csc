---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  variant?: 'light' | 'alt' | 'dark';
}
const { eyebrow, title, lead, variant = 'alt' } = Astro.props;
const bg = variant === 'dark' ? 'bg-dark' : variant === 'alt' ? 'bg-alt' : '';
---

<section class:list={['page-hero', bg]}>
  <div class="container reveal">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="display page-hero-title">{title}</h1>
    {lead && <p class="lead page-hero-lead">{lead}</p>}
  </div>
</section>

<style>
  .page-hero { padding-block: clamp(96px, 16vh, 180px) clamp(48px, 8vh, 88px); }
  .page-hero-title { max-width: 16ch; }
  .page-hero-lead { margin-top: 22px; max-width: 40ch; }
</style>
