---
// Thin line-art "skyline" of electronic components — echoes floema's
// product line drawings, adapted to CSC's world (IC, connector, display, module).
---
<svg class="skyline" viewBox="0 0 1200 220" fill="none" aria-hidden="true" preserveAspectRatio="xMidYMax meet">
  <g stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" stroke-linecap="round">
    <!-- IC chip with pins -->
    <rect x="70" y="150" width="86" height="60" rx="4" />
    <circle cx="84" cy="164" r="4" />
    {Array.from({ length: 6 }).map((_, i) => (
      <line x1={78 + i * 14} y1="150" x2={78 + i * 14} y2="140" />
    ))}
    {Array.from({ length: 6 }).map((_, i) => (
      <line x1={78 + i * 14} y1="210" x2={78 + i * 14} y2="220" />
    ))}

    <!-- Display panel -->
    <rect x="250" y="96" width="150" height="114" rx="6" />
    <rect x="264" y="110" width="122" height="72" rx="3" />
    <line x1="300" y1="196" x2="350" y2="196" />

    <!-- Connector housing -->
    <path d="M470 210 v-52 h96 v52 Z" />
    {Array.from({ length: 7 }).map((_, i) => (
      <line x1={482 + i * 12} y1="158" x2={482 + i * 12} y2="146" />
    ))}
    <line x1="470" y1="176" x2="566" y2="176" />

    <!-- Tall module / signage column -->
    <rect x="650" y="40" width="60" height="170" rx="6" />
    <rect x="664" y="58" width="32" height="46" rx="3" />
    <line x1="680" y1="120" x2="680" y2="210" />

    <!-- Capacitors -->
    <rect x="800" y="120" width="34" height="90" rx="16" />
    <rect x="846" y="140" width="34" height="70" rx="16" />
    <line x1="817" y1="120" x2="817" y2="108" />
    <line x1="863" y1="140" x2="863" y2="128" />

    <!-- Circuit module with cable -->
    <rect x="960" y="150" width="150" height="60" rx="4" />
    <path d="M1035 150 c0 -30 40 -30 40 -58" />
    <circle cx="1075" cy="88" r="6" />
    {Array.from({ length: 8 }).map((_, i) => (
      <line x1={974 + i * 18} y1="210" x2={974 + i * 18} y2="220" />
    ))}
  </g>
</svg>

<style>
  .skyline { width: 100%; height: auto; display: block; color: var(--color-olive-line); }
</style>
