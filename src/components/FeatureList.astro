---
interface Props {
  items: (string | { title: string; desc?: string })[];
  columns?: 1 | 2;
}
const { items, columns = 1 } = Astro.props;
const norm = items.map((i) => (typeof i === 'string' ? { title: i } : i));
---

<ul class:list={['feature-list', { 'cols-2': columns === 2 }]}>
  {norm.map((i) => (
    <li class="feature-item">
      <span class="feature-mark" aria-hidden="true"></span>
      <span class="feature-body">
        <span class="feature-title">{i.title}</span>
        {i.desc && <span class="feature-desc">{i.desc}</span>}
      </span>
    </li>
  ))}
</ul>

<style>
  .feature-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 4px; }
  .feature-list.cols-2 { grid-template-columns: 1fr 1fr; gap: 4px 40px; }
  .feature-item {
    display: flex;
    gap: 18px;
    align-items: flex-start;
    padding: 22px 0;
    border-top: 1px solid var(--color-hairline);
  }
  .bg-dark .feature-item, .bg-navy .feature-item { border-color: rgba(242,240,233,0.18); }
  .feature-mark {
    flex: none;
    width: 8px;
    height: 8px;
    margin-top: 12px;
    background: var(--color-navy);
    border-radius: 50%;
  }
  .bg-dark .feature-mark, .bg-navy .feature-mark { background: var(--color-navy-bright); }
  .feature-title {
    display: block; font-family: var(--font-display);
    font-size: clamp(19px, 1.6vw, 23px); font-weight: 600; letter-spacing: -0.02em;
  }
  .feature-desc { display: block; margin-top: 6px; font-size: 16px; color: var(--color-muted); line-height: 1.5; }
  .bg-dark .feature-desc, .bg-navy .feature-desc { color: rgba(242,240,233,0.6); }

  @media (max-width: 720px) {
    .feature-list.cols-2 { grid-template-columns: 1fr; }
  }
</style>
