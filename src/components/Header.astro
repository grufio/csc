---
import { Image } from 'astro:assets';
import logo from '../assets/images/csc-logo.png';
import { services } from '../data/site';

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path === href + '/';
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand" aria-label="CSC Electronic AG — Startseite">
      <Image src={logo} alt="CSC Electronic AG" class="brand-logo" widths={[300]} loading="eager" />
    </a>

    <nav class="pillbar" aria-label="Hauptnavigation">
      <a href="/wir-ueber-uns" class:list={['pill', { active: isActive('/wir-ueber-uns') }]}>Über uns</a>
      <div class="pill-dd">
        <button class="pill pill-btn" aria-haspopup="true" aria-expanded="false">Leistungen</button>
        <div class="dropdown">
          {services.map((s, i) => (
            <a href={`/${s.slug}`} class="dd-item">
              <span class="dd-index">{String(i + 1).padStart(2, '0')}</span>{s.title}
            </a>
          ))}
        </div>
      </div>
      <a href="/kontakt" class:list={['pill', { active: isActive('/kontakt') }]}>Kontakt</a>
    </nav>

    <span class="lang-pill">DE</span>

    <button class="burger" aria-label="Menü öffnen" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden>
    <nav aria-label="Mobile Navigation">
      <a href="/wir-ueber-uns" class="m-link">Über uns</a>
      <span class="m-head">Leistungen</span>
      {services.map((s, i) => (
        <a href={`/${s.slug}`} class="m-link m-sub"><span class="m-index">{String(i + 1).padStart(2, '0')}</span>{s.title}</a>
      ))}
      <a href="/kontakt" class="m-link">Kontakt</a>
    </nav>
  </div>
</header>

<style>
  .site-header { position: sticky; top: 0; z-index: 100; }
  .header-inner {
    max-width: 1440px; margin-inline: auto; padding: 16px 30px;
    display: flex; align-items: center; gap: 16px;
  }
  .brand { margin-right: auto; }
  .brand-logo { height: 22px; width: auto; }

  /* connected pill bar */
  .pillbar {
    display: flex; align-items: stretch;
    background: rgba(255,255,255,0.72);
    backdrop-filter: saturate(160%) blur(14px);
    -webkit-backdrop-filter: saturate(160%) blur(14px);
    border: 1px solid var(--color-hairline);
    border-radius: 999px;
    padding: 4px;
  }
  .pill {
    display: inline-flex; align-items: center;
    font-family: var(--font-sans);
    font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--color-ink);
    padding: 9px 18px; border-radius: 999px;
    background: transparent; border: none; cursor: pointer;
    transition: background-color 0.25s var(--ease), color 0.25s var(--ease);
    white-space: nowrap;
  }
  .pill:hover, .pill.active { background: var(--color-green); color: var(--color-grey); }
  .pill-btn { font: inherit; font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; }

  .lang-pill {
    display: inline-flex; align-items: center;
    font-size: 12px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 10px 15px; border-radius: 999px;
    background: rgba(255,255,255,0.72);
    backdrop-filter: saturate(160%) blur(14px);
    -webkit-backdrop-filter: saturate(160%) blur(14px);
    border: 1px solid var(--color-hairline);
    color: var(--color-ink);
  }

  .pill-dd { position: relative; display: flex; }
  .dropdown {
    position: absolute; top: calc(100% + 14px); left: 50%; transform: translateX(-50%) translateY(6px);
    width: min(340px, 82vw);
    background: rgba(255,255,255,0.94);
    backdrop-filter: saturate(160%) blur(20px);
    -webkit-backdrop-filter: saturate(160%) blur(20px);
    border: 1px solid var(--color-hairline); border-radius: 18px; padding: 8px;
    opacity: 0; visibility: hidden;
    transition: opacity 0.28s var(--ease), transform 0.28s var(--ease), visibility 0.28s;
    box-shadow: 0 30px 60px -28px rgba(14,42,34,0.45);
  }
  .pill-dd:hover .dropdown, .pill-dd:focus-within .dropdown { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
  .dd-item {
    display: flex; align-items: baseline; gap: 12px;
    padding: 11px 14px; border-radius: 12px; font-size: 14px; font-weight: 500;
    transition: background-color 0.2s var(--ease);
  }
  .dd-item:hover { background: var(--color-grey-2); }
  .dd-index { font-size: 11px; color: var(--color-muted); letter-spacing: 0.06em; }

  .burger { display: none; flex-direction: column; justify-content: center; gap: 6px; width: 42px; height: 42px; background: rgba(255,255,255,0.72); border: 1px solid var(--color-hairline); border-radius: 999px; cursor: pointer; }
  .burger span { display: block; width: 18px; height: 1.5px; background: var(--color-ink); margin-inline: auto; transition: transform 0.3s var(--ease), opacity 0.2s var(--ease); }
  .burger[aria-expanded='true'] span:nth-child(1) { transform: translateY(3.75px) rotate(45deg); }
  .burger[aria-expanded='true'] span:nth-child(2) { transform: translateY(-3.75px) rotate(-45deg); }

  .mobile-menu {
    display: none; margin: 0 30px; padding: 14px 20px 24px;
    background: rgba(255,255,255,0.96);
    backdrop-filter: saturate(160%) blur(20px); -webkit-backdrop-filter: saturate(160%) blur(20px);
    border: 1px solid var(--color-hairline); border-radius: 20px;
  }
  .mobile-menu nav { display: flex; flex-direction: column; }
  .m-link {
    font-family: var(--font-display); font-size: 22px; font-weight: 600; letter-spacing: -0.02em;
    color: var(--color-ink); padding: 13px 0; border-bottom: 1px solid var(--color-hairline);
    display: flex; align-items: baseline; gap: 12px;
  }
  .m-sub { font-size: 17px; font-weight: 500; }
  .m-index { font-size: 12px; color: var(--color-muted); }
  .m-head { font-size: 11px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--color-muted); padding: 18px 0 6px; }

  @media (max-width: 900px) {
    .pillbar, .lang-pill { display: none; }
    .burger { display: flex; }
    .mobile-menu.open { display: block; }
  }
</style>

<script>
  const burger = document.querySelector('.burger');
  const menu = document.getElementById('mobile-menu');
  burger?.addEventListener('click', () => {
    const open = menu?.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(open));
    burger.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen');
    if (menu) menu.hidden = !open;
    document.body.style.overflow = open ? 'hidden' : '';
  });
</script>
