---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import Callout from '../components/Callout.astro';
import ContactCTA from '../components/ContactCTA.astro';

const marquee = ['Komponenten', 'Displays', 'Touchscreen', 'Steckverbinder', 'Kabelkonfektion', 'Obsolete Bauteile', 'China Sourcing', 'Supply Management'];
---

<BaseLayout>
  <Hero />

  <!-- Kinetic marquee band -->
  <div class="marquee-band" aria-hidden="true">
    <div class="marquee">
      <div class="marquee-track">
        {[...marquee, ...marquee].map((w) => <span>{w} <em>—</em> </span>)}
      </div>
    </div>
  </div>

  <ServiceGrid />

  <!-- Statement — dark green, floema-style -->
  <Callout
    small="Try us"
    text="We try harder."
    sub="Als unabhängiger Lieferant beschaffen wir aktive, passive und elektromechanische Komponenten namhafter Hersteller weltweit — von der Anfrage bis zur Auftragsabwicklung."
    variant="green"
    arrow
  />

  <!-- Über uns — editorial, asymmetric -->
  <section class="section bg-alt">
    <div class="container-wide about">
      <p class="eyebrow reveal">Über uns</p>
      <div class="about-row">
        <h2 class="h1 reveal">Partner, nicht<br />nur Lieferant.</h2>
        <div class="about-side reveal">
          <p class="lead">
            Seit 30 Jahren beliefern wir Industriekunden in ganz Europa. Erfahrung,
            Fachkompetenz und ein transparentes, kundenorientiertes Vorgehen machen uns
            zum richtigen Partner.
          </p>
          <p class="about-p">
            Ein weltweites Lieferantennetzwerk und eine eigene Einkaufsorganisation in China
            ermöglichen professionelle Unterstützung bei Beschaffungsthemen jeder Komplexität.
          </p>
          <a href="/wir-ueber-uns" class="link-more">Mehr über uns</a>
        </div>
      </div>
    </div>
  </section>

  <ContactCTA />
</BaseLayout>

<style>
  .marquee-band {
    background: var(--color-acid);
    color: var(--color-ink);
    padding-block: 22px;
    font-size: clamp(26px, 4vw, 52px);
  }
  .marquee-track em { font-style: normal; opacity: 0.55; }

  .about-row {
    margin-top: 26px; display: grid; grid-template-columns: 1fr 1fr;
    gap: clamp(28px, 6vw, 96px); align-items: start;
  }
  .about-side { max-width: 46ch; }
  .about-p { margin-top: 20px; color: var(--color-muted); }
  .about-side .link-more { margin-top: 28px; }
  @media (max-width: 800px) { .about-row { grid-template-columns: 1fr; gap: 24px; } }
</style>
